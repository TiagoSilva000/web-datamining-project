@prefix ont: <http://example.org/webdatamining/ontology/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix prop: <http://example.org/webdatamining/property/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

prop:attack a owl:ObjectProperty ;
    rdfs:label "attack" ;
    rdfs:domain ont:Person ;
    rdfs:range ont:Person .

prop:beRelation a owl:ObjectProperty ;
    rdfs:label "be" .

prop:bearOn a owl:ObjectProperty ;
    rdfs:label "bear_on" ;
    rdfs:domain ont:Work .

prop:beginIn a owl:ObjectProperty ;
    rdfs:label "begin_in" ;
    rdfs:domain ont:Person ;
    rdfs:range ont:DateEntity .

prop:broadcastOn a owl:ObjectProperty ;
    rdfs:label "broadcast_on" ;
    rdfs:domain ont:Work ;
    rdfs:range ont:Organization .

prop:call a owl:ObjectProperty ;
    rdfs:label "call" ;
    rdfs:domain ont:Work ;
    rdfs:range ont:Work .

prop:cast a owl:ObjectProperty ;
    rdfs:label "cast" ;
    rdfs:domain ont:Organization ;
    rdfs:range ont:Person .

prop:cause a owl:ObjectProperty ;
    rdfs:label "cause" ;
    rdfs:domain ont:Place ;
    rdfs:range ont:Event .

prop:choose a owl:ObjectProperty ;
    rdfs:label "choose" ;
