    rdfs:range ont:Person .

prop:enlistIn a owl:ObjectProperty ;
    rdfs:label "enlist_in" ;
    rdfs:domain ont:Organization ;
    rdfs:range ont:DateEntity .

prop:excelIn a owl:ObjectProperty ;
    rdfs:label "excel_in" ;
    rdfs:domain ont:Person .

prop:exitIn a owl:ObjectProperty ;
    rdfs:label "exit_in" ;
    rdfs:domain ont:Person ;
    rdfs:range ont:DateEntity .

prop:followWith a owl:ObjectProperty ;
    rdfs:label "follow_with" ;
    rdfs:domain ont:Person ;
    rdfs:range ont:Work .

prop:foundIn a owl:ObjectProperty ;
    rdfs:label "found_in" ;
    rdfs:domain ont:Organization ;
