prop:opposeIn a owl:ObjectProperty ;
    rdfs:label "oppose_in" ;
    rdfs:domain ont:Organization ;
    rdfs:range ont:DateEntity .

prop:present a owl:ObjectProperty ;
    rdfs:label "present" ;
    rdfs:domain ont:Person ;
    rdfs:range ont:Person .

prop:presentIn a owl:ObjectProperty ;
    rdfs:label "present_in" ;
    rdfs:domain ont:Person ;
    rdfs:range ont:DateEntity .

prop:presentWith a owl:ObjectProperty ;
    rdfs:label "present_with" ;
    rdfs:domain ont:Person ;
    rdfs:range ont:Work .

prop:releaseIn a owl:ObjectProperty ;
    rdfs:label "release_in" ;
    rdfs:domain ont:Organization ;
    rdfs:range ont:DateEntity .

prop:rescue a owl:ObjectProperty ;
    rdfs:label "rescue" ;
