prop:separateFrom a owl:ObjectProperty ;
    rdfs:label "separate_from" ;
    rdfs:domain ont:Person .

prop:serveTo a owl:ObjectProperty ;
    rdfs:label "serve_to" ;
    rdfs:domain ont:Person ;
    rdfs:range ont:Work .

prop:signIn a owl:ObjectProperty ;
    rdfs:label "sign_in" ;
    rdfs:domain ont:Organization ;
    rdfs:range ont:DateEntity .

prop:star a owl:ObjectProperty ;
    rdfs:label "star" ;
    rdfs:domain ont:Work ;
    rdfs:range ont:Person .

prop:televiseIn a owl:ObjectProperty ;
    rdfs:label "televise_in" ;
    rdfs:domain ont:Work ;
    rdfs:range ont:DateEntity .

prop:tell a owl:ObjectProperty ;
    rdfs:label "tell" ;
    rdfs:domain ont:Person ;
    rdfs:range ont:Organization .

prop:tellIn a owl:ObjectProperty ;
    rdfs:label "tell_in" ;
    rdfs:domain ont:Person ;
    rdfs:range ont:DateEntity .

prop:vacateIn a owl:ObjectProperty ;
    rdfs:label "vacate_in" ;
    rdfs:domain ont:Organization ;
    rdfs:range ont:DateEntity .

prop:win a owl:ObjectProperty ;
    rdfs:label "win" ;
    rdfs:domain ont:Person ;
    rdfs:range ont:Work .

prop:winFor a owl:ObjectProperty ;
    rdfs:label "win_for" ;
    rdfs:domain ont:Person ;
    rdfs:range ont:Organization .

prop:winIn a owl:ObjectProperty ;
    rdfs:label "win_in" ;
