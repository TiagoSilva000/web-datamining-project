prop:workOn a owl:ObjectProperty ;
    rdfs:label "work_on" ;
    rdfs:domain ont:Person ;
    rdfs:range ont:DateEntity .

ont:Event a owl:Class ;
    rdfs:label "Event" .

ont:Agent a owl:Class ;
    rdfs:label "Agent" .

ont:Place a owl:Class ;
    rdfs:label "Place" .

ont:Work a owl:Class ;
    rdfs:label "Work" .

ont:Organization a owl:Class ;
    rdfs:label "Organization" ;
    rdfs:subClassOf ont:Agent .

ont:DateEntity a owl:Class ;
    rdfs:label "DateEntity" .

ont:Person a owl:Class ;
    rdfs:label "Person" ;
    rdfs:subClassOf ont:Agent .

