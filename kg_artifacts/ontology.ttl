    rdfs:label "gross" ;
    rdfs:domain ont:Work .

prop:grossBy a owl:ObjectProperty ;
    rdfs:label "gross_by" ;
    rdfs:domain ont:Organization ;
    rdfs:range ont:DateEntity .

prop:grossIn a owl:ObjectProperty ;
    rdfs:label "gross_in" ;
    rdfs:domain ont:Work ;
    rdfs:range ont:Place .

prop:haveAt a owl:ObjectProperty ;
    rdfs:label "have_at" ;
    rdfs:domain ont:Person ;
    rdfs:range ont:Organization .

prop:helm a owl:ObjectProperty ;
    rdfs:label "helm" ;
    rdfs:domain ont:Person ;
    rdfs:range ont:Work .

prop:hold a owl:ObjectProperty ;
    rdfs:label "hold" ;
    rdfs:domain ont:Work ;
    rdfs:range ont:DateEntity .

prop:holdAt a owl:ObjectProperty ;
    rdfs:label "hold_at" ;
    rdfs:domain ont:Work .

prop:initiateIn a owl:ObjectProperty ;
    rdfs:label "initiate_in" ;
